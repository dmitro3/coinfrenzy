# CoinFrenzy — runtime environment for Docker Compose.
#
# Copy to `.env.docker` and fill in. This file is injected into all three
# containers at runtime via `env_file`. Keep real secrets OUT of git.
#
#   [REQUIRED]  must be set for production to boot / function
#   [optional]  has a safe default or is only needed for a specific feature
#
# Generate strong secrets with:  openssl rand -hex 32

# ─── Core ────────────────────────────────────────────────────────────────
NODE_ENV=production

# [REQUIRED] Pooled Neon/Postgres connection string used by all runtime code.
DATABASE_URL=postgres://user:password@host:5432/coinfrenzy?sslmode=require
# [optional] Unpooled URL — only migrations use this (run separately, not by these containers).
DATABASE_URL_DIRECT=
# [optional] Upstash/Redis URL for caching + rate limiting.
REDIS_URL=

# ─── Auth / sessions (REQUIRED in production — min 32 chars each) ─────────
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://coinfrenzy.com
ADMIN_SESSION_SECRET=
# [optional] Previous secret, accepted during the 7-day rotation overlap.
ADMIN_SESSION_SECRET_PREV=
# [optional] DEV ONLY — ignored when NODE_ENV=production. Leave false.
ADMIN_2FA_OPTIONAL=false

# ─── App base URLs ────────────────────────────────────────────────────────
PLAYER_BASE_URL=https://coinfrenzy.com
WEBHOOK_BASE_URL=https://coinfrenzy.com

# ─── Real-time (Pusher) ───────────────────────────────────────────────────
# Server-side (runtime):
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=
# Client-side (inlined at BUILD time — also export these in your shell before
# `docker compose build` so the build args pick them up):
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=

# ─── Inngest (worker) ──────────────────────────────────────────────────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ─── Vendor mock toggles ──────────────────────────────────────────────────
# Default true so the stack boots without live vendor accounts. Flip to
# false ONLY when the matching live credentials below are set. In production
# these gate access to the in-app /mock-vendors surfaces.
USE_MOCK_FINIX=true
USE_MOCK_ALEA=true
USE_MOCK_FOOTPRINT=true
USE_MOCK_RADAR=true
USE_MOCK_SENDGRID=true
USE_MOCK_TWILIO=true
USE_MOCK_EASYSCAM=true

# ─── Payments (Finix) ──────────────────────────────────────────────────────
FINIX_API_KEY=
FINIX_APPLICATION_ID=
FINIX_WEBHOOK_SECRET=
# Inlined at BUILD time (public):
NEXT_PUBLIC_FINIX_APPLICATION_ID=
NEXT_PUBLIC_FINIX_ENVIRONMENT=sandbox

# ─── Game aggregator (Alea) ────────────────────────────────────────────────
ALEA_API_BASE=
ALEA_API_KEY=
ALEA_WEBHOOK_SECRET=
ALEA_CASINO_ID_1=
ALEA_CASINO_ENVIRONMENT_ID_1=
ALEA_CASINO_ID_2=
ALEA_CASINO_ENVIRONMENT_ID_2=

# ─── KYC (Footprint) ───────────────────────────────────────────────────────
FOOTPRINT_API_KEY=
FOOTPRINT_WEBHOOK_SECRET=
FOOTPRINT_PLAYBOOK_ID=

# ─── Risk (Radar) / AMOE (EasyScam) ────────────────────────────────────────
RADAR_API_KEY=
EASYSCAM_API_KEY=
EASYSCAM_API_BASE=
INTERCOM_ACCESS_TOKEN=

# ─── Email (SendGrid) / SMS (Twilio) ───────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_WEBHOOK_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WEBHOOK_SECRET=
TWILIO_FROM_NUMBER=

# ─── Object storage (Cloudflare R2) ────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# ─── Encryption-at-rest (field-level) ──────────────────────────────────────
ENCRYPTION_KEY_CURRENT=
ENCRYPTION_KEY_PREVIOUS=

# ─── Observability ─────────────────────────────────────────────────────────
SENTRY_DSN=
AXIOM_TOKEN=
GRAFANA_API_KEY=
PAGERDUTY_ROUTING_KEY=

# ─── Feature flags ─────────────────────────────────────────────────────────
USE_DB_LOBBY_LAYOUT=true

# ─── Cloudflare Turnstile ──────────────────────────────────────────────────
# NEXT_PUBLIC_CF_TURNSTILE_SITE_KEY must ALSO be exported in your shell
# before running `docker compose build` — it is baked into the client JS
# bundle at build time and is NOT a secret (it appears in browser source).
# Get it from: Cloudflare dashboard → Turnstile → <your site> → Site Key.
NEXT_PUBLIC_CF_TURNSTILE_SITE_KEY=

# CF_TURNSTILE_SECRET_KEY is read at runtime by Edge Middleware (server-side).
# It NEVER reaches the browser. Get it from:
# Cloudflare dashboard → Turnstile → <your site> → Secret Key.
CF_TURNSTILE_SECRET_KEY=
