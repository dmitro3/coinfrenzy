{
  "name": "@coinfrenzy/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*/index.ts"
  },
  "scripts": {
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:unit": "vitest run src/ledger/__tests__/unit",
    "test:properties": "vitest run src/ledger/__tests__/properties.test.ts",
    "smoketest:ledger": "tsx scripts/smoketest-ledger.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1048.0",
    "@aws-sdk/s3-request-presigner": "^3.1048.0",
    "@coinfrenzy/config": "workspace:*",
    "@coinfrenzy/db": "workspace:*",
    "@sendgrid/mail": "^8.1.6",
    "bcryptjs": "^2.4.3",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.36.1",
    "handlebars": "^4.7.9",
    "otplib": "^12.0.1",
    "postgres": "^3.4.4",
    "pusher": "^5.3.3",
    "qrcode": "^1.5.4",
    "twilio": "^6.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^10.13.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.10",
    "@types/qrcode": "^1.5.6",
    "@typescript-eslint/eslint-plugin": "^8.6.0",
    "@typescript-eslint/parser": "^8.6.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "fast-check": "^3.22.0",
    "testcontainers": "^10.13.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
