# CoinFrenzy environment variables
# Copy this file to .env.local for local development.
# Production / staging secrets live in Doppler — see docs/09 §9.
# DO NOT commit .env or .env.local.

NODE_ENV=development
ALEA_ENV=staging # staging, production

# ─── Database ─────────────────────────────────────────────────────────────
DATABASE_URL=
DATABASE_URL_DIRECT=
REDIS_URL=

# ─── Auth ─────────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=
# Player-auth base URL. Local: http://localhost:3000.  Staging/prod: the
# host you actually serve from (must match cookie domain). Better Auth
# rejects mismatches.
BETTER_AUTH_URL=http://localhost:3000
ADMIN_SESSION_SECRET=
ADMIN_SESSION_SECRET_PREV=

# Dev-only escape hatches. Both are hard-rejected at runtime when
# NODE_ENV=production. Leave blank/false for staging too — only flip in a
# personal .env.local while developing.
#
# ADMIN_2FA_OPTIONAL=true skips the TOTP setup wizard for admins whose
# totp_enabled=false (so password-only login works in dev).
ADMIN_2FA_OPTIONAL=false
# DEV_PLAYER_AUTOLOGIN=true bypasses Better Auth on the player surface and
# impersonates the most-recently-active seeded player. Lets a dev open
# /lobby directly without going through signup. See
# apps/web/lib/player-session.ts.
DEV_PLAYER_AUTOLOGIN=false

# ─── Adapters — Alea ──────────────────────────────────────────────────────
ALEA_API_BASE=
ALEA_API_KEY=
ALEA_WEBHOOK_SECRET=
ALEA_CASINO_ID_1=
ALEA_CASINO_ENVIRONMENT_ID_1=
ALEA_CASINO_ID_2=
ALEA_CASINO_ENVIRONMENT_ID_2=

# ─── Adapters — Finix ─────────────────────────────────────────────────────
FINIX_API_KEY=
FINIX_APPLICATION_ID=
FINIX_WEBHOOK_SECRET=

# ─── Adapters — Footprint (KYC) ───────────────────────────────────────────
FOOTPRINT_API_KEY=
FOOTPRINT_WEBHOOK_SECRET=
FOOTPRINT_PLAYBOOK_ID=

# ─── Adapters — Radar (geo) ───────────────────────────────────────────────
RADAR_API_KEY=

# ─── Adapters — Communication ─────────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_WEBHOOK_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WEBHOOK_SECRET=

# ─── Adapters — Other ─────────────────────────────────────────────────────
EASYSCAM_API_KEY=
EASYSCAM_API_BASE=
INTERCOM_ACCESS_TOKEN=

# ─── Vendor-mock toggles (prompt 06) ──────────────────────────────────────
# Default `true` so a fresh checkout never hits a real vendor account. Flip
# the single flag for the vendor whose live credentials you've wired into
# Doppler. The adapter factory in @coinfrenzy/core picks mock vs real off
# these. The admin Integrity page badges every tile with "Mock Mode" while
# the flag is on.
USE_MOCK_FINIX=true
USE_MOCK_ALEA=true
USE_MOCK_FOOTPRINT=true
USE_MOCK_RADAR=true
USE_MOCK_SENDGRID=true
USE_MOCK_TWILIO=true
USE_MOCK_EASYSCAM=true

# Base URLs used by mock vendor pages + real adapters' return URLs.
# In production these should point to the live player + webhook hosts.
PLAYER_BASE_URL=http://localhost:3000
WEBHOOK_BASE_URL=http://localhost:3000

# ─── Infrastructure ───────────────────────────────────────────────────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# ─── Real-time (Pusher Channels — docs/10 §7) ─────────────────────────────
# Server-side credentials (used by web API routes + worker publisher):
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=
# Client-side (must be NEXT_PUBLIC_*; only the key + cluster are public):
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=

# ─── Observability ────────────────────────────────────────────────────────
SENTRY_DSN=
AXIOM_TOKEN=
GRAFANA_API_KEY=
PAGERDUTY_ROUTING_KEY=

# ─── App-layer encryption (sensitive field encryption) ────────────────────
ENCRYPTION_KEY_CURRENT=
ENCRYPTION_KEY_PREVIOUS=

# ─── One-time bootstrap (used only by `pnpm --filter @coinfrenzy/db db:seed-admin`)
# These are NOT loaded by the app at runtime; they are only read by the
# seed-admin.ts script. After the first admin exists you can remove them.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_NAME=
