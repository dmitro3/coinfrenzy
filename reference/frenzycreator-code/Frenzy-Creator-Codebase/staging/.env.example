# ─── CoinFrenzy Cron API ─────────────────────────────────────────────────────
# Required: API key for authenticating with the CoinFrenzy cron API.
# Obtain from your CoinFrenzy account or integration contact.
COINFRENZY_CRON_API_KEY=

# Optional: Override the default cron base URL (no trailing slash).
# Defaults to: https://dev2-cron.coinfrenzy.com/api/v1/frenzy-creator
COINFRENZY_CRON_BASE_URL=

# Optional: Enable the /api/coinfrenzy/health diagnostic endpoint.
# Set to any non-empty secret string, then call:
#   GET /api/coinfrenzy/health?secret=<your-secret>
COINFRENZY_CRON_DEBUG_SECRET=

# ─── Webhook Auth ────────────────────────────────────────────────────────────
# Required: Shared secret CoinFrenzy sends as "Authorization: Bearer <key>"
# when calling your /api/webhook/player-registration endpoint.
# Set this to whatever value you configure on the CoinFrenzy side.
FRENZY_CREATOR_API_KEY=

# ─── Supabase ────────────────────────────────────────────────────────────────
# Required for the player-registration webhook (server-side only).
# Get both values from: Supabase dashboard → Project → Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Admin Session Auth ───────────────────────────────────────────────────────
# Required: Secret used to sign admin HMAC session tokens (issued by POST /api/admin/session).
# Generate a strong random value: openssl rand -hex 32
ADMIN_SESSION_SECRET=

# ─── Partner Session Auth ─────────────────────────────────────────────────────
# Required: Secret used to sign partner HMAC session tokens (issued by POST /api/partner/session).
# Generate a strong random value: openssl rand -hex 32
PARTNER_SESSION_SECRET=

# ─── CORS ────────────────────────────────────────────────────────────────────
# Optional: Restrict proxy routes to your production domain.
# Defaults to: https://frenzycreator.com
ALLOWED_ORIGIN=https://frenzycreator.com
