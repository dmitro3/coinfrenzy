{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "incremental": true,
    "declaration": false,
    "declarationMap": false,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@coinfrenzy/core": ["../../packages/core/src/index.ts"],
      "@coinfrenzy/core/*": ["../../packages/core/src/*"],
      "@coinfrenzy/db": ["../../packages/db/src/index.ts"],
      "@coinfrenzy/db/*": ["../../packages/db/src/*"],
      "@coinfrenzy/ui": ["../../packages/ui/src/index.ts"],
      "@coinfrenzy/ui/*": ["../../packages/ui/src/*"],
      "@coinfrenzy/config": ["../../packages/config/src/index.ts"],
      "@coinfrenzy/config/*": ["../../packages/config/src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules", ".next"]
}
